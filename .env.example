# Copy to .env.local for local development. See design/tech-stack.md §3 for
# the full reference (including which of these belong in Vercel vs. GitHub
# Actions secrets) and docs/deployment.md for the step-by-step setup guide.

# --- Required — Next.js app (Vercel) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Powers BOTH job scoring AND resume suggestions / application drafting /
# careers-page extraction (decisions.md AD-42) -- no second LLM key needed
# by default. See LLM_PROVIDER below to opt a caller into Gemini/Anthropic
# direct instead.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# --- Required — cron scripts (GitHub Actions secrets only; never set these in Vercel) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional (all have code-level defaults; see design/tech-stack.md §3) ---
# KEYWORD_THRESHOLD=0.25
# NOTIFY_THRESHOLD=0.75
# NOTIFY_MODE=individual
# APP_URL=
# TELEGRAM_CALLBACK_SECRET=
# WELLFOUND_FEED_URL=
# WELLFOUND_DISABLED=
# REMOTEOK_DISABLED=
# RAPIDAPI_KEY=
# JSEARCH_DISABLED=
# JSEARCH_COUNTRIES=in,sg,ae
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_DISABLED=
# ADZUNA_COUNTRIES=in,sg
# JOB_EXPIRATION_DAYS=14
# OPENROUTER_MAX_TOKENS=300
# OPENROUTER_MAX_RESUME_PROMPT_CHARS=4000
# OPENROUTER_MAX_DESCRIPTION_PROMPT_CHARS=2000
# OPENROUTER_COST_PER_1K_TOKENS=
# SOURCE_DISABLE_THRESHOLD=7
# MIN_HEALTHY_SOURCE_COUNT=3
# SCORING_STUCK_THRESHOLD_HOURS=48
# SOURCE_STALE_HOURS=6
# LLM_PROVIDER=openrouter   # openrouter (default) | gemini | anthropic -- see decisions.md AD-42
# LLM_MODEL=
# GEMINI_API_KEY=           # only needed if LLM_PROVIDER=gemini
# ANTHROPIC_API_KEY=        # only needed if LLM_PROVIDER=anthropic
